@using System.Globalization
@model AutoOglasi.Web.ViewModels.Posts.SinglePostViewModel

@{
    ViewData["Title"] = $"{Model.Car.Make} {Model.Car.Model}";
    ViewData["Description"] = Model.Car.Description;
    ViewData["Image"] = $"{Context.Request.Scheme}://{Context.Request.Host}{Model.Car.Images.FirstOrDefault()}";
}

<div class="container-xl py-4">
    
    <!-- Karusel sa velikim slikama -->
    <div class="luxury-hero-container mb-5">
        <div id="postCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
            <div class="carousel-inner">
                @for (int i = 0; i < Model.Car.Images.Count; i++)
                {
                    var img = Model.Car.Images[i];
                    <div class="carousel-item @(i == 0 ? "active" : "")">
                        <img src="@img" class="d-block luxury-carousel-img" alt="Hypercar view" />
                    </div>
                }
            </div>
            <button class="carousel-control-prev" type="button" data-bs-target="#postCarousel" data-bs-slide="prev">
                <span class="carousel-control-prev-icon" aria-hidden="true"></span>
            </button>
            <button class="carousel-control-next" type="button" data-bs-target="#postCarousel" data-bs-slide="next">
                <span class="carousel-control-next-icon" aria-hidden="true"></span>
            </button>
        </div>
    </div>

    <!-- Sličice (Thumbnails) ispod karusela -->
    <div class="row justify-content-center mb-5">
        <div class="col-12 col-lg-10">
            <div class="row row-cols-5 g-2">
                @for (int i = 0; i < Model.Car.Images.Count; i++)
                {
                    <div class="col">
                        <img src="@Model.Car.Images[i]" 
                             class="w-100 luxury-thumb" 
                             data-bs-target="#postCarousel" 
                             data-bs-slide-to="@i" 
                             alt="Thumbnail" />
                    </div>
                }
            </div>
        </div>
    </div>

    <!-- Glavno zaglavlje sa nazivom i cenom -->
    <div class="row justify-content-center mb-5 text-center text-lg-start">
        <div class="col-12 col-lg-10 d-flex flex-column flex-lg-row justify-content-between align-items-center">
            <div>
                <span class="text-uppercase small luxury-gold-sub" style="letter-spacing: 4px;">Exclusive Collection</span>
                <h1 class="display-5 fw-bold text-uppercase mt-1 mb-2 text-theme-heading" style="letter-spacing: 2px;">
                    @Model.Car.Make @Model.Car.Model
                </h1>
                <p class="small luxury-text-muted"><i class="fas fa-clock me-2"></i>Curated on @Model.PublishedOn</p>
            </div>
            <div class="mt-4 mt-lg-0 text-center text-lg-end">
                <span class="small text-uppercase d-block luxury-text-muted" style="letter-spacing: 2px;">Investment Value</span>
                <span class="display-5 fw-bold luxury-price-tag">
                    €@Model.Car.Price.ToString("N0", CultureInfo.CurrentCulture)
                </span>
            </div>
        </div>
    </div>

    <!-- Mreža sa specifikacijama (Technical Specifications) -->
    <div class="row justify-content-center g-4 mb-5">
        <div class="col-12 col-lg-10">
            <div class="row row-cols-2 row-cols-md-3 g-3">
                <div class="col">
                    <div class="p-4 h-100 border border-secondary border-opacity-10 luxury-spec-box">
                        <div class="text-uppercase small pb-1 luxury-spec-label" style="letter-spacing: 2px; font-size: 0.75rem;">Year of Production</div>
                        <div class="fs-4 fw-light luxury-spec-value">@Model.Car.Year</div>
                    </div>
                </div>
                <div class="col">
                    <div class="p-4 h-100 border border-secondary border-opacity-10 luxury-spec-box">
                        <div class="text-uppercase small pb-1 luxury-spec-label" style="letter-spacing: 2px; font-size: 0.75rem;">Transmission</div>
                        <div class="fs-4 fw-light luxury-spec-value">@Model.Car.TransmissionType</div>
                    </div>
                </div>
                <div class="col">
                    <div class="p-4 h-100 border border-secondary border-opacity-10 luxury-spec-box">
                        <div class="text-uppercase small pb-1 luxury-spec-label" style="letter-spacing: 2px; font-size: 0.75rem;">Engine Performance</div>
                        <div class="fs-4 fw-light luxury-spec-value">@Model.Car.Horsepower <span class="fs-6 luxury-text-muted">BHP</span></div>
                    </div>
                </div>
                <div class="col">
                    <div class="p-4 h-100 border border-secondary border-opacity-10 luxury-spec-box">
                        <div class="text-uppercase small pb-1 luxury-spec-label" style="letter-spacing: 2px; font-size: 0.75rem;">Fuel & Drivetrain</div>
                        <div class="fs-4 fw-light luxury-spec-value">@Model.Car.FuelType</div>
                    </div>
                </div>
                <div class="col">
                    <div class="p-4 h-100 border border-secondary border-opacity-10 luxury-spec-box">
                        <div class="text-uppercase small pb-1 luxury-spec-label" style="letter-spacing: 2px; font-size: 0.75rem;">Location</div>
                        <div class="fs-4 fw-light text-truncate luxury-spec-value">@Model.Car.LocationCity</div>
                    </div>
                </div>
                <div class="col">
                    <div class="p-4 h-100 border border-secondary border-opacity-10 luxury-spec-box">
                        <div class="text-uppercase small pb-1 luxury-spec-label" style="letter-spacing: 2px; font-size: 0.75rem;">Status</div>
                        <div class="fs-4 fw-light luxury-status-active">Available</div>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <!-- Opis i Kontakt podaci agenta -->
    <div class="row justify-content-center g-5 mb-5">
        <div class="col-12 col-lg-6">
            <h3 class="fw-light mb-4 pb-2 border-bottom border-secondary border-opacity-25 text-theme-heading" style="letter-spacing: 2px;">The Story</h3>
            <p class="lh-lg luxury-story-text" style="white-space: pre-line; font-size: 0.95rem; font-family: monospace;">
                @Model.Car.Description
            </p>
        </div>
        
        <div class="col-12 col-lg-4">
            <div class="p-4 border border-secondary border-opacity-25 text-center luxury-agent-card">
                <h4 class="fw-light mb-2 text-theme-heading" style="letter-spacing: 2px;">Private Viewing</h4>
                <p class="small mb-4 luxury-text-muted">Serious inquiries only. Schedule a private inspection.</p>
                
                <hr class="border-secondary opacity-25 mb-4" />

                <div class="mb-3">
                    <span class="text-uppercase d-block small pb-1 luxury-text-muted" style="letter-spacing: 1px;">Managing Concierge</span>
                    <span class="fs-5 fw-light luxury-agent-value">@Model.SellerName</span>
                </div>

                <div class="mb-4">
                    <span class="text-uppercase d-block small pb-1 luxury-text-muted" style="letter-spacing: 1px;">Origin</span>
                    <span class="fs-6 luxury-text-muted">@Model.Car.LocationCity, @Model.Car.LocationCountry</span>
                </div>

                <a href="tel:@Model.SellerPhoneNumber" class="btn border text-uppercase py-3 w-100 fw-bold luxury-agent-btn">
                    <i class="fas fa-phone-alt me-2"></i> Contact Agent
                </a>
            </div>
        </div>
    </div>

</div>

@section Scripts
{
    <script src="~/js/owlcarousel/owl.carousel.min.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            $('.owl-carousel').owlCarousel({
                lazyLoad: true,
                loop: true,
                responsive: true
            });
        });
    </script>
}
