@using Microsoft.AspNetCore.Identity;
@model AutoOglasi.Data.Models.RoleEdit

@{
    ViewData["Title"] = "Access Control";
}

<div class="py-3 justify-content-center row">
    <div class="col-12 col-xl-10">

        <!-- Naslov i validacija -->
        <div class="text-center mb-5">
            <span class="text-uppercase small font-monospace" style="letter-spacing: 4px; color: #d4af37;">Security Dashboard</span>
            <h2 class="text-white fw-light text-uppercase mt-1" style="letter-spacing: 1px;">Update Role: <span class="fw-normal" style="color: #d4af37;">@Model.Role.Name</span></h2>
            <div class="mx-auto mt-2" style="width: 40px; height: 1px; background-color: #d4af37;"></div>
        </div>

        <div asp-validation-summary="All" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

        <form method="post" class="row g-4 justify-content-between">
            <input type="hidden" name="roleName" value="@Model.Role.Name" />
            <input type="hidden" name="roleId" value="@Model.Role.Id" />

            <!-- LEVA KARTICA: Dodavanje korisnika (Non-Members) -->
            <div class="col-12 col-md-6">
                <div class="card h-100 luxury-card">
                    <div class="card-header bg-black bg-opacity-30 border-bottom border-secondary border-opacity-10 p-3 text-center">
                        <h5 class="text-white text-uppercase tracking-wider m-0" style="font-size: 0.9rem; letter-spacing: 1px;">
                            <i class="fas fa-user-plus me-2 text-muted"></i> Assign to Role
                        </h5>
                    </div>
                    
                    <div class="card-body p-3 table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-hover align-middle m-0 text-white-50">
                            <tbody>
                                @if (!Model.NonMembers.Any())
                                {
                                    <tr>
                                        <td colspan="2" class="text-center py-4 font-monospace small text-muted">
                                            All system users possess this role.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (IdentityUser user in Model.NonMembers)
                                    {
                                        <tr class="border-bottom border-secondary border-opacity-10">
                                            <td class="text-white fw-light py-2 ps-2">@user.UserName</td>
                                            <td class="text-end pe-2 py-2" style="width: 40px;">
                                                <div class="form-check d-inline-block">
                                                    <input type="checkbox" name="AddIds" value="@user.Id" class="form-check-input rounded-0" style="background-color: transparent; border-color: rgba(255,255,255,0.2);">
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>
                </div>
            </div>

            <!-- DESNA KARTICA: Uklanjanje korisnika (Members) -->
            <div class="col-12 col-md-6">
                <div class="card h-100 luxury-card">
                    <div class="card-header bg-black bg-opacity-30 border-bottom border-secondary border-opacity-10 p-3 text-center">
                        <h5 class="text-white text-uppercase tracking-wider m-0" style="font-size: 0.9rem; letter-spacing: 1px;">
                            <i class="fas fa-user-shield me-2 text-muted"></i> Current Members
                        </h5>
                    </div>
                    
                    <div class="card-body p-3 table-responsive" style="max-height: 400px; overflow-y: auto;">
                        <table class="table table-hover align-middle m-0 text-white-50">
                            <tbody>
                                @if (!Model.Members.Any())
                                {
                                    <tr>
                                        <td colspan="2" class="text-center py-4 font-monospace small text-muted" style="color: #ff6b6b !important;">
                                            No users currently assigned to this privilege.
                                        </td>
                                    </tr>
                                }
                                else
                                {
                                    @foreach (IdentityUser user in Model.Members)
                                    {
                                        <tr class="border-bottom border-secondary border-opacity-10">
                                            <td class="text-white fw-light py-2 ps-2">@user.UserName</td>
                                            <td class="text-end pe-2 py-2" style="width: 40px;">
                                                <div class="form-check d-inline-block">
                                                    <input type="checkbox" name="DeleteIds" value="@user.Id" class="form-check-input rounded-0" style="background-color: transparent; border-color: rgba(255,255,255,0.2);">
                                                </div>
                                            </td>
                                        </tr>
                                    }
                                }
                            </tbody>
                        </table>
                    </div>

                    <!-- Footer sa brojačem članova -->
                    <div class="card-footer bg-black bg-opacity-10 border-top border-secondary border-opacity-10 p-3 text-center">
                        <span class="text-uppercase small font-monospace tracking-wider text-muted" style="font-size: 0.75rem;">
                            Total Active Members: 
                            <span class="fw-bold ms-1" style="color: #d4af37;">@Model.Members.Count()</span>
                        </span>
                    </div>
                </div>
            </div>

            <!-- Dugmad za akciju na dnu -->
            <div class="col-12 text-center pt-4 d-md-flex justify-content-center gap-3">
                <button type="submit" class="btn text-uppercase py-3 px-5 fw-bold border mb-2 mb-md-0 d-block d-md-inline-block w-100 w-md-auto" 
                        style="color: #d4af37; border-color: #d4af37 !important; letter-spacing: 2px; font-size: 0.85rem; background: transparent; transition: all 0.3s;">
                    Save Changes
                </button>
                
                <a asp-action="Index" class="btn text-uppercase py-3 px-5 rounded-0 border d-block d-md-inline-block w-100 w-md-auto"
                   style="color: #c5c6c7; border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.02); font-size: 0.85rem; letter-spacing: 2px;">
                    Back to Registry
                </a>
            </div>
        </form>

    </div>
</div>
