@page
@model RegisterModel

@{
    ViewData["Title"] = "Join the Salon";
}

<div class="d-flex justify-content-center align-items-center py-5">
    <div class="card luxury-card shadow-lg luxury-auth-card">
        <div class="card-body p-4 p-md-5">

            <div class="text-center mb-4">
                <span class="text-uppercase small font-monospace luxury-gold-sub-text luxury-sub-spacing-sm">Membership</span>
                <h2 class="fw-light text-uppercase mt-1 text-theme-heading luxury-title-spacing">Create Account</h2>
                <div class="mx-auto mt-2 luxury-deco-line-sm"></div>
            </div>

            <form id="registerForm" method="post" asp-antifrogery="true">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-0 small" role="alert"></div>

                <div class="form-floating mb-3 luxury-form-floating">
                    <input asp-for="Input.FullName" class="form-control rounded-0 luxury-input-field" placeholder="Full name" />
                    <label asp-for="Input.FullName" class="text-muted">Full name</label>
                    <span asp-validation-for="Input.FullName" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3 luxury-form-floating">
                    <input asp-for="Input.Email" class="form-control rounded-0 luxury-input-field" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="text-muted">Email address</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3 luxury-form-floating">
                    <input asp-for="Input.Password" class="form-control rounded-0 luxury-input-field" autocomplete="new-password" placeholder="password" />
                    <label asp-for="Input.Password" class="text-muted">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-4 luxury-form-floating">
                    <input asp-for="Input.ConfirmPassword" class="form-control rounded-0 luxury-input-field" autocomplete="new-password" placeholder="confirm password" />
                    <label asp-for="Input.ConfirmPassword" class="text-muted">Confirm Password</label>
                    <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
                </div>

                <button id="register-submit" type="submit" class="btn text-uppercase py-3 w-100 fw-bold border mb-2 luxury-btn-gold-outline luxury-btn-size-md luxury-tracking-wide">
                    Register
                </button>
            </form>

            <hr class="my-4 border-secondary opacity-10" />

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <div class="text-center mb-3">
                    <p class="mb-3 text-muted small">Or register with</p>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="d-grid gap-2">
                        @foreach (var provider in Model.ExternalLogins)
                        {
                            <button type="submit" class="btn btn-outline-secondary py-2 text-uppercase small" name="provider" value="@provider.Name" title="Register using your @provider.DisplayName account">
                                @provider.DisplayName
                            </button>
                        }
                    </form>
                </div>
                <hr class="my-4 border-secondary opacity-10" />
            }

            <div class="text-center">
                <p class="mb-3 text-muted small">Already a registered investor?</p>
                <a asp-page="./Login" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-sm text-uppercase py-2 w-100 rounded-0 border luxury-btn-cancel luxury-auth-btn-register">
                    Sign In
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}