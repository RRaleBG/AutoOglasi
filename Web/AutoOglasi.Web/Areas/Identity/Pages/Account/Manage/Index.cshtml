@page
@model Microsoft.AspNetCore.Identity.UI.Pages.Account.Manage.Internal.IndexModel
@{
    ViewData["Title"] = "Profile";
}

<h4 class="text-uppercase font-monospace mb-4 luxury-profile-section-title">
    Primary Credentials
</h4>

<partial name="_StatusMessage" model="@((string)ViewData["StatusMessage"] ?? (string)TempData["StatusMessage"])" />

<form id="profile-form" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

    <div class="form-floating mb-3 luxury-form-floating">
        <input type="text" class="form-control rounded-0 luxury-input-field-disabled" value="@User.Identity?.Name" placeholder="Username" disabled />
        <label class="text-muted">Username / Identity</label>
    </div>

    <div class="form-floating mb-4 luxury-form-floating">
        <input type="tel" name="Input.PhoneNumber" id="phoneNumberInput" class="form-control rounded-0 font-monospace luxury-input-field" placeholder="Phone Number" />
        <label for="phoneNumberInput" class="text-muted">Contact Phone Line</label>
    </div>

    <button id="update-profile-button" type="submit" class="btn text-uppercase py-2.5 px-4 fw-bold border luxury-profile-save-btn">
        Save Profile Changes
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
