@using Microsoft.AspNetCore.Identity
@using AutoOglasi.Data.Models
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<div class="dropdown">
    <nav class="navbar p-0">
        <ul class="navbar-nav sm text-center">

            @if (SignInManager.IsSignedIn(User))
            {
                var __user = await UserManager.GetUserAsync(User);
                var __avatar = __user?.ProfileImagePath;

                <li class="nav-item">
                    <!-- Dugme za Dropdown korisnika -->
                    <a class="btn btn-outline-secondary bg-transparent border-0 dropdown-toggle d-flex align-items-center gap-2 luxury-user-toggle" href="#" role="button" data-bs-toggle="dropdown" aria-expanded="false">
                        @if (!string.IsNullOrEmpty(__avatar))
                        {
                            <img src="@Url.Content(__avatar)" alt="avatar" class="rounded-circle" style="width:36px;height:36px;object-fit:cover;" />
                        }
                        else
                        {
                            <span class="bi bi-person luxury-user-icon"></span>
                        }

                        <strong class="luxury-username">
                            @User.Identity.Name.ToUpper().Substring(0,1)@User.Identity.Name.Substring(0,User.Identity.Name.IndexOf('@')).ToLower().Substring(1)
                        </strong>
                    </a>

                    <!-- Meni na spuštanje -->
                    <ul class="dropdown-menu p-2 nav-underline flex-column shadow luxury-dropdown-menu">

                        @if (User.IsInRole("Administrator"))
                        {
                            <li class="nav-item text-center" title="Approve new car"> 
                                <a class="nav-link fw-semibold" asp-area="Admin" asp-controller="Posts" asp-action="All" asp-route-id="1">Administration</a>  
                            </li>           
                            <li class="nav-item text-center" title="Asign user to role">  
                                <a class="nav-link fw-semibold" asp-area="Admin" asp-controller="Role" asp-action="Index">Role</a>  
                            </li>
                        }                            
                        @if(User.IsInRole("Users"))
                        {
                            <li class="nav-item text-center" title="My cars">   
                                <a class="nav-link fw-semibold" asp-area="" asp-controller="Posts" asp-action="Mine" asp-route-id="1">My cars</a>    
                            </li>

                            <li class="nav-item text-center" title="Add new car">   
                                <a class="nav-link fw-semibold" asp-area="" asp-controller="Posts" asp-action="Create">Sell car </a>                 
                            </li>
                        }

                        <li class="nav-item text-center">  
                            <a class="nav-link fw-semibold" asp-area="Identity" asp-page="/Account/Manage/Index" title="Manage">
                                <strong>Profile</strong>
                            </a>   
                        </li>

                        <li><hr class="dropdown-divider luxury-divider"></li>

                        <li class="nav-item text-center">
                            <form class="form-inline" asp-area="Identity" asp-page="/Account/Logout" asp-route-returnUrl="@Url.Action("Index", "Home", new { area = "" })">
                                <button type="submit" class="dropdown-item btn btn-link text-center luxury-logout-btn">Logout</button>
                            </form>
                        </li>
                    </ul>
                </li>            
            }
            else
            {
                <li class="nav-item">
                    <a class="nav-link fw-semibold luxury-nav-link" asp-area="Identity" asp-page="/Account/Register">Register</a>
                </li>
                <li class="nav-item">
                    <a class="nav-link fw-semibold luxury-nav-link" asp-area="Identity" asp-page="/Account/Login">Login</a>
                </li>
            }
        </ul>
    </nav>
</div>
@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}