@model string
@{
    ViewData["Title"] = "Create Privilege";
}

<div class="py-5 justify-content-center row">
    <div class="col-12 col-md-6 col-lg-5">

        <div class="text-center mb-4">
            <span class="text-uppercase small font-monospace luxury-gold-sub-text luxury-sub-spacing">Security Hub</span>
            <h2 class="fw-light text-uppercase mt-1 text-theme-heading luxury-title-spacing">Create New Role</h2>
            <div class="mx-auto mt-2 luxury-deco-line-sm"></div>
        </div>

        <div class="card luxury-card shadow-lg">
            <div class="card-body p-4 p-md-5">

                <div asp-validation-summary="All" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

                <form asp-action="Create" method="post">

                    <div class="form-floating mb-4 luxury-form-floating">
                        <input name="name" id="roleNameInput" class="form-control rounded-0 luxury-input-field" placeholder="Role name" required />
                        <label for="roleNameInput" class="text-muted">Role Name</label>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-between pt-2">
                        <button type="submit" class="btn text-uppercase py-2.5 px-4 fw-bold border order-md-2 luxury-btn-gold-outline luxury-btn-size-sm">
                            <i class="fas fa-check-circle me-1"></i> Create Role
                        </button>
                        
                        <a asp-action="Index" class="btn text-uppercase py-2.5 px-4 rounded-0 border order-md-1 luxury-btn-cancel luxury-btn-size-sm">
                            Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>
