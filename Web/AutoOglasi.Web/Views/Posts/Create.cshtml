@model AutoOglasi.Web.ViewModels.Posts.PostFormInputModel

@{
    ViewData["Title"] = "Asset Listing";
}

<div class="py-4 justify-content-center row">
    <div class="col-12 col-lg-10 col-xl-9">

        <!-- Naslov sekcije - Čist HTML sa semantičkim klasama -->
        <div class="text-center mb-5">
            <span class="text-uppercase small font-monospace luxury-gold-sub-text">Showroom Registration</span>
            <h2 class="text-theme-heading fw-light text-uppercase mt-1 luxury-title-spacing">List Your Vehicle</h2>
            <div class="mx-auto mt-2 luxury-deco-line"></div>
        </div>

        <!-- Glavni boks forme -->
        <form method="post" class="luxury-search-form p-4 p-md-5 border border-secondary border-opacity-10" enctype="multipart/form-data">
            
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

            <!-- Proizvođač i Model -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label asp-for="@Model.Car.Make" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size"></label>
                    <input asp-for="@Model.Car.Make" class="form-control py-2.5 rounded-0" placeholder="e.g., Porsche, Ferrari, Aston Martin...">
                    <span asp-validation-for="@Model.Car.Make" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="@Model.Car.Model" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size"></label>
                    <input asp-for="@Model.Car.Model" class="form-control py-2.5 rounded-0" placeholder="e.g., 911 Turbo S, SF90, Vantage...">
                    <span asp-validation-for="@Model.Car.Model" class="text-danger small"></span>
                </div>
            </div>

            <!-- Padajući meniji (Kategorija, Gorivo, Menjač) -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.CategoryId" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Category</label>
                    <select asp-for="@Model.Car.CategoryId" class="form-select py-2.5 rounded-0 luxury-select-pointer" asp-items="@(new SelectList(Model.Car.Categories, "Id", "Name"))">
                        <option disabled selected hidden>Select category</option>
                    </select>
                    <span asp-validation-for="@Model.Car.CategoryId" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.FuelTypeId" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Propulsion</label>
                    <select asp-for="@Model.Car.FuelTypeId" class="form-select py-2.5 rounded-0 luxury-select-pointer" asp-items="@(new SelectList(Model.Car.FuelTypes, "Id", "Name"))">
                        <option disabled selected hidden>Select fuel type</option>
                    </select>
                    <span asp-validation-for="@Model.Car.FuelTypeId" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.TransmissionTypeId" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Transmission</label>
                    <select asp-for="@Model.Car.TransmissionTypeId" class="form-select py-2.5 rounded-0 luxury-select-pointer" asp-items="@(new SelectList(Model.Car.TransmissionTypes, "Id", "Name"))">
                        <option disabled selected hidden>Select transmission</option>
                    </select>
                    <span asp-validation-for="@Model.Car.TransmissionTypeId" class="text-danger small"></span>
                </div>
            </div>

            <!-- Godina, Kilometraža, Snaga -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Year" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size"></label>
                    <input asp-for="@Model.Car.Year" min="1900" max="@DateTime.UtcNow.Year + 1" class="form-control py-2.5 rounded-0 font-monospace" placeholder="Year">
                    <span asp-validation-for="@Model.Car.Year" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Kilometers" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Mileage (KM)</label>
                    <input asp-for="@Model.Car.Kilometers" min="0" class="form-control py-2.5 rounded-0 font-monospace" placeholder="Kilometers">
                    <span asp-validation-for="@Model.Car.Kilometers" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Horsepower" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Output (BHP)</label>
                    <input asp-for="@Model.Car.Horsepower" min="0" class="form-control py-2.5 rounded-0 font-monospace" placeholder="Horsepower">
                    <span asp-validation-for="@Model.Car.Horsepower" class="text-danger small"></span>
                </div>
            </div>

            <!-- Cena i Slike -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Price" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Requested Valuation (€)</label>
                    <input asp-for="@Model.Car.Price" min="0" class="form-control py-2.5 rounded-0 font-monospace" placeholder="Price (€)">
                    <span asp-validation-for="@Model.Car.Price" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-8">
                    <label asp-for="@Model.Car.Images" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Media Assets Gallery</label>
                    <input asp-for="@Model.Car.Images" class="form-control py-2 rounded-0 small" />
                    <span asp-validation-for="@Model.Car.Images" class="text-danger small d-block mt-1"></span>
                    <span class="text-danger small d-block mt-1">@Html.ValidationMessage("CustomError")</span>
                </div>
            </div>

            <!-- Država i Grad -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label asp-for="@Model.Car.LocationCountry" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Country</label>
                    <input asp-for="@Model.Car.LocationCountry" class="form-control py-2.5 rounded-0" placeholder="Country location">
                    <span asp-validation-for="@Model.Car.LocationCountry" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="@Model.Car.LocationCity" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">City / Region</label>
                    <input asp-for="@Model.Car.LocationCity" class="form-control py-2.5 rounded-0" placeholder="City location">
                    <span asp-validation-for="@Model.Car.LocationCity" class="text-danger small"></span>
                </div>
            </div>

            <!-- Detaljan opis -->
            <div class="mb-5">
                <label asp-for="@Model.Car.Description" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-label-size">Detailed Overview</label>
                <textarea asp-for="@Model.Car.Description" class="form-control rounded-0" rows="4" placeholder="Provide an exclusive description of technical packages, service history, and vehicle status..."></textarea>
                <span asp-validation-for="@Model.Car.Description" class="text-danger small"></span>
            </div>

            <!-- Kontakt informacije (Unutrašnji panel) -->
            <div class="p-4 mb-4 luxury-stats-box border border-secondary border-opacity-10">
                <h6 class="text-theme-heading text-uppercase font-monospace mb-4 text-center luxury-agent-header-text">
                    <i class="far fa-address-card me-2"></i> Representative Contact Information
                </h6>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="@Model.SellerName" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-agent-label-size">Full Name / Agent Title</label>
                        <input asp-for="@Model.SellerName" class="form-control py-2.5 rounded-0" placeholder="Your name">
                        <span asp-validation-for="@Model.SellerName" class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="@Model.SellerPhoneNumber" class="form-label text-uppercase small font-monospace text-muted tracking-wider luxury-agent-label-size">Secure Direct Line</label>
                        <input asp-for="@Model.SellerPhoneNumber" class="form-control py-2.5 rounded-0 font-monospace" placeholder="+381...">
                        <span asp-validation-for="@Model.SellerPhoneNumber" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <!-- Premium dugme za objavu oglasa -->
            <div class="text-center pt-3">
                <button type="submit" class="btn text-uppercase py-3 px-5 fw-bold border w-100 w-md-auto luxury-search-btn">
                    <i class="fas fa-file-upload me-2"></i> Authorize & Publish Listing
                </button>
            </div>

        </form>
    </div>
</div>
