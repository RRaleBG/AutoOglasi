
@page
@model dynamic
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="col-12 col-md-6 col-lg-5 p-4 bg-dark bg-opacity-25 border border-secondary border-opacity-10 shadow-lg">
        
        <h2 class="text-white text-uppercase font-monospace text-center mb-2" style="letter-spacing: 2px; font-size: 1.6rem;">
            Recovery Vault
        </h2>
        <p class="text-muted text-center small font-monospace mb-4" style="color: #bfa15f !important;">
            Enter your email to reset credentials
        </p>

        <partial name="_StatusMessage" model="@((string)ViewData["StatusMessage"] ?? (string)TempData["StatusMessage"])" />

        <form method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="form-floating mb-4">
                <input type="email" name="Input.Email" id="emailInput" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 rounded-0 font-monospace" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                <label for="emailInput" class="text-muted">Registered Email Address</label>
            </div>

            <button type="submit" class="btn text-uppercase py-2.5 w-100 fw-bold border" 
                    style="color: #d4af37; border-color: #d4af37 !important; letter-spacing: 2px; font-size: 0.85rem; background: transparent; transition: all 0.3s;">
                Send Reset Link
            </button>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
