
@page
@model Microsoft.AspNetCore.Identity.UI.Pages.Account.Manage.Internal.IndexModel
@{
    ViewData["Title"] = "Profile";
}

<h4 class="text-white text-uppercase font-monospace mb-4" style="font-size: 1.1rem; letter-spacing: 1px; color: #bfa15f !important;">
    Primary Credentials
</h4>

<partial name="_StatusMessage" model="@((string)ViewData["StatusMessage"] ?? (string)TempData["StatusMessage"])" />

<form id="profile-form" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

    <div class="form-floating mb-3">
        <input type="text" class="form-control text-white-50 bg-dark bg-opacity-10 border-secondary border-opacity-25 rounded-0" value="@User.Identity?.Name" placeholder="Username" disabled />
        <label class="text-muted">Username / Identity</label>
    </div>

    <div class="form-floating mb-4">
        <input type="tel" name="Input.PhoneNumber" id="phoneNumberInput" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 rounded-0 font-monospace" placeholder="Phone Number" />
        <label for="phoneNumberInput" class="text-muted">Contact Phone Line</label>
    </div>

    <button id="update-profile-button" type="submit" class="btn text-uppercase py-2.5 px-4 fw-bold border" 
            style="color: #d4af37; border-color: #d4af37 !important; letter-spacing: 2px; font-size: 0.8rem; background: transparent; transition: all 0.3s;">
        Save Portfolio Changes
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
