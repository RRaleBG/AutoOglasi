@model AutoOglasi.Web.ViewModels.Posts.EditPostViewModel

@{
    ViewData["Title"] = "Modify Listing";
}

<div class="py-4 justify-content-center row">
    <div class="col-12 col-lg-10 col-xl-9">

        <div class="text-center mb-5">
            <span class="text-uppercase small font-monospace luxury-gold-sub-text">Management Console</span>
            <h2 class="text-theme-heading fw-light text-uppercase mt-1 luxury-title-spacing">Edit Listing</h2>
            <div class="mx-auto mt-2 luxury-deco-line"></div>
        </div>

        <form method="post" class="luxury-search-form p-4 p-md-5 border border-secondary border-opacity-10" enctype="multipart/form-data">
            
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label asp-for="@Model.Car.Make" class="form-label text-uppercase small font-monospace text-muted luxury-label-size"></label>
                    <input asp-for="@Model.Car.Make" class="form-control py-2.5 rounded-0" placeholder="e.g., Porsche...">
                    <span asp-validation-for="@Model.Car.Make" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="@Model.Car.Model" class="form-label text-uppercase small font-monospace text-muted luxury-label-size"></label>
                    <input asp-for="@Model.Car.Model" class="form-control py-2.5 rounded-0" placeholder="e.g., 911...">
                    <span asp-validation-for="@Model.Car.Model" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.CategoryId" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Category</label>
                    <select asp-for="@Model.Car.CategoryId" class="form-select py-2.5 rounded-0 luxury-select-pointer" asp-items="@(new SelectList(Model.Car.Categories, "Id", "Name"))">
                        <option disabled>Choose category</option>
                    </select>
                    <span asp-validation-for="@Model.Car.CategoryId" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.FuelTypeId" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Propulsion</label>
                    <select asp-for="@Model.Car.FuelTypeId" class="form-select py-2.5 rounded-0 luxury-select-pointer" asp-items="@(new SelectList(Model.Car.FuelTypes, "Id", "Name"))">
                        <option disabled>Choose fuel type</option>
                    </select>
                    <span asp-validation-for="@Model.Car.FuelTypeId" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.TransmissionTypeId" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Transmission</label>
                    <select asp-for="@Model.Car.TransmissionTypeId" class="form-select py-2.5 rounded-0 luxury-select-pointer" asp-items="@(new SelectList(Model.Car.TransmissionTypes, "Id", "Name"))">
                        <option disabled>Choose transmission</option>
                    </select>
                    <span asp-validation-for="@Model.Car.TransmissionTypeId" class="text-danger small"></span>
                </div>
            </div>

            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Year" class="form-label text-uppercase small font-monospace text-muted luxury-label-size"></label>
                    <input asp-for="@Model.Car.Year" class="form-control py-2.5 rounded-0 font-monospace">
                    <span asp-validation-for="@Model.Car.Year" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Kilometers" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Mileage (KM)</label>
                    <input asp-for="@Model.Car.Kilometers" class="form-control py-2.5 rounded-0 font-monospace">
                    <span asp-validation-for="@Model.Car.Kilometers" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Horsepower" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Output (BHP)</label>
                    <input asp-for="@Model.Car.Horsepower" class="form-control py-2.5 rounded-0 font-monospace">
                    <span asp-validation-for="@Model.Car.Horsepower" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4 mt-md-3">
                    <label asp-for="@Model.Car.Price" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Valuation (€)</label>
                    <input asp-for="@Model.Car.Price" class="form-control py-2.5 rounded-0 font-monospace">
                    <span asp-validation-for="@Model.Car.Price" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4 mt-md-3">
                    <label asp-for="@Model.Car.LocationCountry" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Country</label>
                    <input asp-for="@Model.Car.LocationCountry" class="form-control py-2.5 rounded-0">
                    <span asp-validation-for="@Model.Car.LocationCountry" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4 mt-md-3">
                    <label asp-for="@Model.Car.LocationCity" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">City</label>
                    <input asp-for="@Model.Car.LocationCity" class="form-control py-2.5 rounded-0">
                    <span asp-validation-for="@Model.Car.LocationCity" class="text-danger small"></span>
                </div>
            </div>

            <div class="mb-4">
                <label asp-for="@Model.Car.Description" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Overview</label>
                <textarea asp-for="@Model.Car.Description" class="form-control rounded-0" rows="3"></textarea>
                <span asp-validation-for="@Model.Car.Description" class="text-danger small"></span>
            </div>

            <div class="p-4 mb-4 luxury-stats-box border border-secondary border-opacity-10">
                <h6 class="text-theme-heading text-uppercase font-monospace mb-4 text-center luxury-agent-header-text">
                    <i class="far fa-images me-2"></i> Manage Asset Gallery
                </h6>
                
                <div id="owl-demo" class="row g-3 row-cols-1 row-cols-sm-2 row-cols-md-3">
                    @foreach (var image in Model.CurrentImages)
                    {
                        <div class="col">
                            <div class="card luxury-card rounded-0 p-2 h-100 border border-secondary border-opacity-10">
                                <div class="ratio ratio-16x9 mb-2">
                                    <img src="@image.Path" class="object-fit-cover item" alt="Gallery Asset" />
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center px-1">
                                    <div class="form-check">
                                        <input id="cover_@image.Id" class="form-check-input rounded-0 luxury-checkbox luxury-select-pointer" type="checkbox" name="SelectedCoverImageId" value="@image.Id" @(Model.SelectedCoverImageId == image.Id ? "checked" : "")>
                                        <label class="form-check-label small font-monospace text-muted luxury-checkbox-label-size" for="cover_@image.Id">Cover</label>
                                    </div>

                                    <div class="form-check">
                                        <input id="deleted_@image.Id" class="form-check-input rounded-0 border-danger bg-opacity-10 luxury-select-pointer" type="checkbox" name="DeletedImagesIds" value="@image.Id" @(Model.DeletedImagesIds.Contains(image.Id) ? "checked" : "")>
                                        <label class="form-check-label small font-monospace text-danger luxury-checkbox-label-size" for="deleted_@image.Id">Delete</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <div class="mt-4 pt-3 border-top border-secondary border-opacity-10">
                    <label asp-for="@Model.Car.Images" class="form-label text-uppercase small font-monospace text-muted luxury-label-size">Upload Additional Media Assets</label>
                    <input asp-for="@Model.Car.Images" class="form-control py-2 rounded-0 small" />
                    <span asp-validation-for="@Model.Car.Images" class="text-danger small d-block mt-1"></span>
                    <span class="text-danger small d-block mt-1">@Html.ValidationMessage("CustomError")</span>
                </div>
            </div>

            <div class="p-4 mb-4 luxury-stats-box border border-secondary border-opacity-10">
                <h6 class="text-theme-heading text-uppercase font-monospace mb-4 text-center luxury-agent-header-text">
                    <i class="far fa-address-card me-2"></i> Representative Contact Details
                </h6>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="@Model.SellerName" class="form-label text-uppercase small font-monospace text-muted luxury-agent-label-size"></label>
                        <input asp-for="@Model.SellerName" class="form-control py-2.5 rounded-0">
                        <span asp-validation-for="@Model.SellerName" class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="@Model.SellerPhoneNumber" class="form-label text-uppercase small font-monospace text-muted luxury-agent-label-size"></label>
                        <input asp-for="@Model.SellerPhoneNumber" class="form-control py-2.5 rounded-0 font-monospace">
                        <span asp-validation-for="@Model.SellerPhoneNumber" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <input type="hidden" asp-for="@Model.CreatorId" />
            <input type="hidden" asp-for="@Model.CarId" />

            <div class="text-center pt-2">
                <button type="submit" class="btn text-uppercase py-3 px-5 fw-bold border w-100 w-md-auto luxury-search-btn">
                    <i class="fas fa-save me-2"></i> Save Changes
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts
{
    <script src="~/js/owlcarousel/owl.carousel.min.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            $('input[id^=cover_][type="checkbox"]').change(function () {
                $('input[id^=cover_][type="checkbox"]').not(this).prop('checked', false);
                $(this).closest('.card').find('input[id^=deleted_][type="checkbox"]').prop('checked', false);
            });

            $('input[id^=deleted_][type="checkbox"]').change(function () {
                $(this).closest('.card').find('input[id^=cover_][type="checkbox"]').prop('checked', false);
            });
        });
    </script>
}
