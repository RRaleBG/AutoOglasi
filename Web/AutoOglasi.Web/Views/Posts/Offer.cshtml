@model AutoOglasi.Web.ViewModels.Posts.SinglePostViewModel

@{   ViewData["Title"] = $"{Model.Car.Make} {Model.Car.Model}"; }




<div class="d-flex justify-content-between align-items-center my-3">
    <small class="text-muted">@Model.PublishedOn</small>
    <h1 class="text-center text-primary">@ViewData["Title"]</h1>
    <h4 class="text-success fw-bold">
        € @Model.Car.Price.ToString("N0", CultureInfo.CurrentCulture)
    </h4>
</div>


<div class="justify-content-center">
    <hr class="border-info" />
    <div class="row">
        @* Description *@
        <div class="col-md-4 mt-3">

            <h4 class="mb-3 text-center">Description</h4> @Model.Car.Description <hr class="my-3 border-info" />

            @* Car details *@
            <h4 class="mb-4 text-center mt-3">Car details</h4>

            @* Model *@
            <h6 class="mt-3 "> Model: <i> @Model.Car.Model</i></h6>

            @* Make: *@
            <h6 class="mt-3 ">Make: <i> @Model.Car.Make</i></h6>

            @* Transmission *@
            <h6 class="mt-3">Transmission: <i> @Model.Car.TransmissionType</i></h6>

            @* Year: *@
            <h6 class="mt-3 ">Year: <i>@Model.Car.Year</i></h6>

            @* Fuel type: *@
            <h6 class="mt-3">Fuel type: <i>@Model.Car.FuelType</i></h6>

            @* Horse power: *@
            <h6 class="mt-3">Horse power: <i>@(Model.Car.Horsepower)Hp</i></h6>

            @* Price: *@            
            <h4 class="text-success fw-bold">
               Price:  € @Model.Car.Price.ToString("N0", CultureInfo.CurrentCulture)
            </h4>

            <hr class="border-info mt-lg-4 mb-3" />


            @*  Seller information  *@
            <div class="row mt-3 mb-3">
                <div class="col-md-12">
                    <div class="card shadow-info bg-body">
                        <h6 class="text-center py-3"> Seller information:</h6>
                        <ul class="list-group list-group-flush">
                            <li class="list-group-item"> <span class="text-info fas fa-user-alt"></span>&nbsp;&nbsp; @Model.SellerName</li>
                            <li class="list-group-item"> <span class="text-info fas fa-phone-alt"></span> &nbsp;&nbsp; @Model.SellerPhoneNumber</li>
                            <li class="list-group-item"><span class="text-info fas fa-map-marker-alt"></span>&nbsp;&nbsp; @Model.Car.LocationCity, @Model.Car.LocationCountry</li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>


        @* Cover image *@
        <div class="col">
            <div class="row justify-content-evenly">
                <div id="postCarousel" class="carousel slide mb-3" data-bs-ride="carousel">
                    <div class="carousel-inner">
                        @for (int i = 0; i < Model.Car.Images.Count; i++)
                        {
                            var img = Model.Car.Images[i];
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@img" class="d-block w-100 rounded shadow" style="height:400px; object-fit:cover;" alt="car image" />
                            </div>
                        }
                    </div>
                </div>



                @* Small images *@
                <div class="pb-0 mt-2 ">
                    <div class="row gy-3 row-cols-1 row-cols-sm-2 row-cols-md-3 ">
                        @foreach (var image in Model.Car.Images)
                        {
                            <img src="@image" class="imgInCarousel rounded-4 py-2" style="height:11em auto;" alt="gallery" />
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts
{
    <script src="~/js/owlcarousel/owl.carousel.min.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            $('.owl-carousel').owlCarousel({
                lazyLoad: true,
                loop: true,
                response: true
            })
        });
    </script>
}