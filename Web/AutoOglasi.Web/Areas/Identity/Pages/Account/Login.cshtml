@page
@model LoginModel

@{
    ViewData["Title"] = "Log in";
}

<div class="d-flex justify-content-center align-items-center">
    <div class="card shadow-lg border-0 rounded-3" style="max-width:420px; width:100%;">
        <div class="card-body p-4">
            <h2 class="text-center mb-4 fw-bold text-primary">Welcome Back</h2>
            <p class="text-center text-muted mb-4">Sign in to continue to AutoOglasi</p>

            <form id="account" method="post" asp-antiforgery="true">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger" role="alert"></div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Email" class="form-control" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email">Email address</label>
                    <span asp-validation-for="Input.Email" class="text-danger"></span>
                </div>

                <div class="form-floating mb-3">
                    <input asp-for="Input.Password" class="form-control" autocomplete="current-password" placeholder="password" />
                    <label asp-for="Input.Password">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-3">
                    <div class="form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input" />
                        <label asp-for="Input.RememberMe" class="form-check-label"></label>
                    </div>
                    <a asp-page="./ForgotPassword" class="small text-decoration-none">Forgot password?</a>
                </div>

                <button id="login-submit" type="submit" class="btn btn-primary btn-lg w-100">Log in</button>
            </form>

            <hr class="my-4" />

            <div class="text-center">
                <p class="mb-2">Don't have an account?</p>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-outline-primary w-100 mb-2">Register</a>
                <a asp-page="./ResendEmailConfirmation" class="btn btn-outline-secondary w-100">Resend email confirmation</a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
