@using System.Globalization
@model AutoOglasi.Web.ViewModels.Posts.PostsListViewModel

@{
    ViewData["Title"] = "The Showroom";
}

<div class="py-2">
    <div class="p-3 mb-4 bg-black bg-opacity-30 border border-secondary border-opacity-10">
        <partial name="_SortingPartial" model="@Model" />
    </div>

    <div class="row justify-content-center g-4">
        @foreach (var post in Model.Posts)
        {
            <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 luxury-card">
                    
                    <div class="d-flex justify-content-between align-items-center p-3" style="background: rgba(0,0,0,0.2);">
                        <small class="text-muted" style="font-size: 0.75rem;">
                            <i class="far fa-calendar-alt me-1"></i>@post.PublishedOn
                        </small>
                        <span class="fw-bold" style="color: #d4af37; font-size: 0.95rem;">
                            € @post.Car.Price.ToString("N0", CultureInfo.InvariantCulture)
                        </span>
                    </div>

                    <a asp-action="Offer" asp-route-id="@post.Id" class="text-decoration-none">
                        <div class="luxury-card-img-wrapper">
                            <img src="@post.Car.CoverImage"
                                 class="luxury-card-img"
                                 alt="@($"{post.Car.Make} {post.Car.Model}")" />
                        </div>
                    </a>

                    <div class="card-body d-flex flex-column justify-content-between text-center p-3">
                        <div>
                            <h5 class="text-white text-uppercase tracking-wide mb-2" style="font-size: 1.1rem; letter-spacing: 1px;">
                                @post.Car.Make <span class="fw-light text-muted">@post.Car.Model</span>
                            </h5>
                            
                            <hr class="my-2 border-secondary opacity-10" />

                            <p class="text-muted small font-monospace m-0" style="font-size: 0.8rem;">
                                @post.Car.Year • @post.Car.FuelType • @post.Car.Kilometers.ToString("N0", CultureInfo.InvariantCulture) km
                            </p>
                            <p class="text-muted small font-monospace mb-2" style="font-size: 0.8rem;">
                                @post.Car.TransmissionType
                            </p>
                        </div>

                        <div class="mt-2">
                            <span class="small tracking-wider text-uppercase" style="color: #bfa15f; font-size: 0.75rem; letter-spacing: 1px;">
                                <i class="fas fa-map-marker-alt me-1"></i>@post.Car.LocationCity
                            </span>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>

    <div class="mt-5 p-3 border-top border-secondary border-opacity-10">
        <partial name="_PagingPartial" model="@Model" />
    </div>
</div>

@section Scripts
{
    <script>
        $(document).ready(function () {
            $("#sortingDropDown").change(function () {
                const sortingValue = $(this).val();
                const url = new URL(window.location.href);
                url.searchParams.set("sorting", sortingValue);
                window.location.href = url;
            });
        });
    </script>
}
