@model AutoOglasi.Web.ViewModels.ErrorViewModel

@{
    ViewData["Title"] = "Error";
}

@if (Model.ShowRequestId)
{
    <p class="luxury-error-request">
        <strong>Request ID:</strong> <code>@Model.RequestId</code>
    </p>
}

<div class="text-center luxury-error-container">
    @if (Model.StatusCode == "401")
    {
        <h1 class="luxury-error-code">Error @Model.StatusCode :(</h1>
        <h2 class="luxury-error-message">Unfortunately, you are NOT authorized to see this page.</h2>
    }
    else if (Model.StatusCode == "404")
    {
        <h1 class="luxury-error-code">Error @Model.StatusCode :(</h1>
        <h2 class="luxury-error-message">We are sorry, but the page you requested cannot be found.</h2>
    }
    else
    {
        <h1 class="luxury-error-code">Ooops, Error :(</h1>
        <h2 class="luxury-error-message">Unfortunately, an error occurred while processing your request.</h2>
    }
</div>
