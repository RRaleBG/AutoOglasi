@model AutoOglasi.Web.ViewModels.Posts.EditPostViewModel

@{
    ViewData["Title"] = "Modify Listing";
}

<div class="py-4 justify-content-center row">
    <div class="col-12 col-lg-10 col-xl-9">

        <!-- Elegantan Naslov Forme -->
        <div class="text-center mb-5">
            <span class="text-uppercase small font-monospace" style="letter-spacing: 4px; color: #d4af37;">Management Console</span>
            <h2 class="text-white fw-light text-uppercase mt-1" style="letter-spacing: 1px;">Edit Listing</h2>
            <div class="mx-auto mt-2" style="width: 40px; height: 1px; background-color: #d4af37;"></div>
        </div>

        <form method="post" class="bg-black bg-opacity-20 p-4 p-md-5 border border-secondary border-opacity-10" enctype="multipart/form-data">
            
            <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

            <!-- SEKCIJA 1: Osnovni podaci -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-6">
                    <label asp-for="@Model.Car.Make" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"></label>
                    <input asp-for="@Model.Car.Make" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0" placeholder="e.g., Porsche...">
                    <span asp-validation-for="@Model.Car.Make" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-6">
                    <label asp-for="@Model.Car.Model" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"></label>
                    <input asp-for="@Model.Car.Model" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0" placeholder="e.g., 911...">
                    <span asp-validation-for="@Model.Car.Model" class="text-danger small"></span>
                </div>
            </div>

            <!-- SEKCIJA 2: Klasifikacija -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.CategoryId" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Category</label>
                    <select asp-for="@Model.Car.CategoryId" class="form-select text-white bg-dark border-secondary border-opacity-25 py-2.5 rounded-0" style="cursor: pointer;">
                        <option disabled>Choose category</option>
                        @foreach (var category in Model.Car.Categories)
                        {
                            <option value="@category.Id" class="bg-dark text-white">@category.Name</option>
                        }
                    </select>
                    <span asp-validation-for="@Model.Car.CategoryId" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.FuelTypeId" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Propulsion</label>
                    <select asp-for="@Model.Car.FuelTypeId" class="form-select text-white bg-dark border-secondary border-opacity-25 py-2.5 rounded-0" style="cursor: pointer;">
                        <option disabled>Choose fuel type</option>
                        @foreach (var fuelType in Model.Car.FuelTypes)
                        {
                            <option value="@fuelType.Id" class="bg-dark text-white">@fuelType.Name</option>
                        }
                    </select>
                    <span asp-validation-for="@Model.Car.FuelTypeId" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.TransmissionTypeId" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Transmission</label>
                    <select asp-for="@Model.Car.TransmissionTypeId" class="form-select text-white bg-dark border-secondary border-opacity-25 py-2.5 rounded-0" style="cursor: pointer;">
                        <option disabled>Choose transmission</option>
                        @foreach (var transmissionType in Model.Car.TransmissionTypes)
                        {
                            <option value="@transmissionType.Id" class="bg-dark text-white">@transmissionType.Name</option>
                        }
                    </select>
                    <span asp-validation-for="@Model.Car.TransmissionTypeId" class="text-danger small"></span>
                </div>
            </div>

            <!-- SEKCIJA 3: Performanse, Geografija i Finansije -->
            <div class="row g-3 mb-4">
                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Year" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;"></label>
                    <input asp-for="@Model.Car.Year" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0 font-monospace">
                    <span asp-validation-for="@Model.Car.Year" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Kilometers" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Mileage (KM)</label>
                    <input asp-for="@Model.Car.Kilometers" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0 font-monospace">
                    <span asp-validation-for="@Model.Car.Kilometers" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4">
                    <label asp-for="@Model.Car.Horsepower" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Output (BHP)</label>
                    <input asp-for="@Model.Car.Horsepower" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0 font-monospace">
                    <span asp-validation-for="@Model.Car.Horsepower" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4 mt-md-3">
                    <label asp-for="@Model.Car.Price" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Valuation (€)</label>
                    <input asp-for="@Model.Car.Price" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0 font-monospace">
                    <span asp-validation-for="@Model.Car.Price" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4 mt-md-3">
                    <label asp-for="@Model.Car.LocationCountry" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Country</label>
                    <input asp-for="@Model.Car.LocationCountry" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0">
                    <span asp-validation-for="@Model.Car.LocationCountry" class="text-danger small"></span>
                </div>

                <div class="col-12 col-md-4 mt-md-3">
                    <label asp-for="@Model.Car.LocationCity" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">City</label>
                    <input asp-for="@Model.Car.LocationCity" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0">
                    <span asp-validation-for="@Model.Car.LocationCity" class="text-danger small"></span>
                </div>
            </div>

            <!-- SEKCIJA 4: Opis -->
            <div class="mb-4">
                <label asp-for="@Model.Car.Description" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.75rem; letter-spacing: 1px;">Overview</label>
                <textarea asp-for="@Model.Car.Description" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 rounded-0" rows="3"></textarea>
                <span asp-validation-for="@Model.Car.Description" class="text-danger small"></span>
            </div>

            <!-- SEKCIJA 5: Upravljanje trenutnim fotografijama (Galerijski Menadžer) -->
            <div class="p-4 mb-4 bg-black bg-opacity-40 border border-secondary border-opacity-10">
                <h6 class="text-white text-uppercase font-monospace mb-4 text-center" style="font-size: 0.85rem; letter-spacing: 2px; color: #bfa15f !important;">
                    <i class="far fa-images me-2"></i> Manage Asset Gallery
                </h6>
                
                <div id="owl-demo" class="row g-3 row-cols-1 row-cols-sm-2 row-cols-md-3">
                    @foreach (var image in Model.CurrentImages)
                    {
                        <div class="col">
                            <div class="card bg-dark bg-opacity-40 rounded-0 p-2 h-100 border border-secondary border-opacity-10">
                                <div class="ratio ratio-16x9 mb-2">
                                    <img src="@image.Path" class="object-fit-cover item" alt="Gallery Asset" />
                                </div>
                                
                                <div class="d-flex justify-content-between align-items-center px-1">
                                    <!-- Cover opcija -->
                                    <div class="form-check">
                                        <input id="cover_@image.Id" class="form-check-input rounded-0" type="checkbox" name="SelectedCoverImageId" value="@image.Id" @(Model.SelectedCoverImageId == image.Id ? "checked" : "") style="cursor: pointer;">
                                        <label class="form-check-label small font-monospace text-muted" for="cover_@image.Id" style="font-size: 0.7rem; cursor: pointer;">Cover</label>
                                    </div>

                                    <!-- Delete opcija -->
                                    <div class="form-check">
                                        <input id="deleted_@image.Id" class="form-check-input rounded-0 border-danger bg-opacity-10" type="checkbox" name="DeletedImagesIds" value="@image.Id" @(Model.DeletedImagesIds.Contains(image.Id) ? "checked" : "") style="cursor: pointer;">
                                        <label class="form-check-label small font-monospace text-danger" for="deleted_@image.Id" style="font-size: 0.7rem; cursor: pointer;">Delete</label>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                </div>

                <!-- Dodavanje još fotografija -->
                <div class="mt-4 pt-3 border-top border-secondary border-opacity-10">
                    <label asp-for="@Model.Car.Images" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.7rem; letter-spacing: 1px;">Upload Additional Media Assets</label>
                    <input asp-for="@Model.Car.Images" class="form-control text-muted bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2 rounded-0 small" />
                    <span asp-validation-for="@Model.Car.Images" class="text-danger small d-block mt-1"></span>
                    <span class="text-danger small d-block mt-1">@Html.ValidationMessage("CustomError")</span>
                </div>
            </div>

            <!-- SEKCIJA 6: Kontakt informacije -->
            <div class="p-4 mb-4 bg-black bg-opacity-40 border border-secondary border-opacity-10">
                <h6 class="text-white text-uppercase font-monospace mb-4 text-center" style="font-size: 0.85rem; letter-spacing: 2px; color: #bfa15f !important;">
                    <i class="far fa-address-card me-2"></i> Representative Contact Details
                </h6>
                <div class="row g-3">
                    <div class="col-12 col-md-6">
                        <label asp-for="@Model.SellerName" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.7rem; letter-spacing: 1px;"></label>
                        <input asp-for="@Model.SellerName" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0">
                        <span asp-validation-for="@Model.SellerName" class="text-danger small"></span>
                    </div>

                    <div class="col-12 col-md-6">
                        <label asp-for="@Model.SellerPhoneNumber" class="form-label text-uppercase small font-monospace text-muted" style="font-size: 0.7rem; letter-spacing: 1px;"></label>
                        <input asp-for="@Model.SellerPhoneNumber" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 py-2.5 rounded-0 font-monospace">
                        <span asp-validation-for="@Model.SellerPhoneNumber" class="text-danger small"></span>
                    </div>
                </div>
            </div>

            <input type="hidden" asp-for="@Model.CreatorId" />
            <input type="hidden" asp-for="@Model.CarId" />

            <!-- Dugme za čuvanje -->
            <div class="text-center pt-2">
                <button type="submit" class="btn text-uppercase py-3 px-5 fw-bold border w-100 w-md-auto" 
                        style="color: #d4af37; border-color: #d4af37 !important; letter-spacing: 3px; font-size: 0.85rem; background: transparent; transition: all 0.3s;">
                    <i class="fas fa-save me-2" style="font-size: 0.85rem;"></i> Save Changes
                </button>
            </div>

        </form>
    </div>
</div>

@section Scripts
{
    <script src="~/js/owlcarousel/owl.carousel.min.js" asp-append-version="true"></script>
    <script>
        $(document).ready(function () {
            $('input[id^=cover_][type="checkbox"]').change(function () {
                $('input[id^=cover_][type="checkbox"]').not(this).prop('checked', false);
                $(this).closest('.card').find('input[id^=deleted_][type="checkbox"]').prop('checked', false);
            });

            $('input[id^=deleted_][type="checkbox"]').change(function () {
                $(this).closest('.card').find('input[id^=cover_][type="checkbox"]').prop('checked', false);
            });
        });
    </script>
}
