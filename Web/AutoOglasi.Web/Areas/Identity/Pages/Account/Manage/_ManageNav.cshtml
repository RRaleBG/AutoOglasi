@using AutoOglasi.Data.Models
@inject SignInManager<ApplicationUser> SignInManager

@{
    var currentPath = ViewContext.ActionDescriptor.DisplayName ?? string.Empty;
}

<ul class="nav nav-pills flex-column font-monospace small text-uppercase luxury-manage-nav">
    <li class="nav-item mb-1">
        <a class="nav-link rounded-0 text-start py-2.5 @(currentPath.Contains("Index") ? "active" : string.Empty)" 
           id="profile" asp-page="./Index">
            <i class="fas fa-user-edit me-2 opacity-50"></i> Profile
        </a>
    </li>
    <li class="nav-item mb-1">
        <a class="nav-link rounded-0 text-start py-2.5 @(currentPath.Contains("ChangePassword") ? "active" : string.Empty)" 
           id="change-password" asp-page="./ChangePassword">
            <i class="fas fa-key me-2 opacity-50"></i> Password
        </a>
    </li>
</ul>
