@model IEnumerable<IdentityRole>
@using Microsoft.AspNetCore.Identity

@{
    ViewData["Title"] = "Role Registry";
}

<div class="py-3 justify-content-center row">
    <div class="col-12 col-md-10 col-lg-8">

        <div class="text-center mb-5">
            <span class="text-uppercase small font-monospace luxury-gold-sub-text luxury-sub-spacing">Security Hub</span>
            <h2 class="fw-light text-uppercase mt-1 text-theme-heading luxury-title-spacing">Access Roles</h2>
            <div class="mx-auto mt-2 luxury-deco-line"></div>
        </div>

        <div class="card luxury-card shadow-lg">
            
            <div class="card-header border-bottom border-secondary border-opacity-10 p-3 d-flex justify-content-between align-items-center luxury-card-header-bg">
                <span class="text-uppercase small font-monospace text-muted luxury-label-spacing">System Privileges</span>
                <a asp-action="Create" class="btn btn-sm text-uppercase py-2 px-3 fw-bold border luxury-btn-gold-outline">
                    <i class="fas fa-plus-circle me-1"></i> Create New Role
                </a>
            </div>

            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover align-middle m-0 text-center luxury-admin-table">
                        
                        <thead class="text-uppercase font-monospace small luxury-table-header">
                            <tr class="border-bottom border-secondary border-opacity-25">
                                <th scope="col" class="py-3 text-start ps-4">Role Name</th>
                                <th scope="col" class="py-3 luxury-col-width-config">Configuration</th>
                                <th scope="col" class="py-3 text-end pe-4 luxury-col-width-auth">Authorization</th>
                            </tr>
                        </thead>
                        
                        <tbody>
                            @foreach (var role in Model)
                            {
                                <tr class="border-bottom border-secondary border-opacity-10 luxury-table-row">
                                    <td class="text-start ps-4 fw-light py-3 text-theme-heading">
                                        <i class="fas fa-user-tag me-2 text-muted luxury-role-icon-size"></i>@role.Name
                                    </td>
                                    
                                    <td class="py-3">
                                        <a class="btn btn-sm rounded-0 text-uppercase font-monospace text-decoration-none px-3 py-1.5 d-block luxury-admin-btn-edit" 
                                           asp-action="Update" asp-route-id="@role.Id">
                                            Update
                                        </a>
                                    </td>
                                    
                                    <td class="py-3 text-end pe-4">
                                        <form asp-action="Delete" asp-route-id="@role.Id" method="post" class="m-0">
                                            <button type="submit" class="btn btn-sm rounded-0 text-uppercase font-monospace px-3 py-1.5 d-block w-100 luxury-admin-btn-delete" 
                                                    onclick="return confirm('Are you certain you want to permanently revoke this role?');">
                                                Delete
                                            </button>
                                        </form>
                                    </td>
                                </tr>
                            }
                        </tbody>

                    </table>
                </div>
            </div>

        </div>
    </div>
</div>
