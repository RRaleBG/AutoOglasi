@using System.Globalization
@model AutoOglasi.Web.ViewModels.Posts.PostsListViewModel

@{
    ViewData["Title"] = "The Showroom";
}

<div class="py-2">
    <!-- Traka za sortiranje na vrhu - sada koristi klasu koja menja boju prema temi -->
    <div class="p-3 mb-4 luxury-sorting-bar border border-secondary border-opacity-10">
        <partial name="_SortingPartial" model="@Model" />
    </div>

    <div class="row justify-content-center g-4">
        @foreach (var post in Model.Posts)
        {
            <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                <div class="card h-100 luxury-card">
                    
                    <!-- Gornja traka sa datumom i cenom -->
                    <div class="d-flex justify-content-between align-items-center p-3 luxury-card-header">
                        <small class="luxury-card-date">
                            <i class="far fa-calendar-alt me-1"></i>@post.PublishedOn
                        </small>
                        <span class="fw-bold luxury-card-price">
                            € @post.Car.Price.ToString("N0", CultureInfo.InvariantCulture)
                        </span>
                    </div>

                    <!-- Slika automobila sa wrap-erom za hover efekat -->
                    <a asp-action="Offer" asp-route-id="@post.Id" class="text-decoration-none">
                        <div class="luxury-card-img-wrapper">
                            <img src="@post.Car.CoverImage"
                                 class="luxury-card-img"
                                 alt="@($"{post.Car.Make} {post.Car.Model}")" />
                        </div>
                    </a>

                    <!-- Telo kartice sa detaljima -->
                    <div class="card-body d-flex flex-column justify-content-between text-center p-3 luxury-card-body">
                        <div>
                            <h5 class="text-uppercase tracking-wide mb-2 luxury-card-title">
                                @post.Car.Make <span class="fw-light luxury-card-model">@post.Car.Model</span>
                            </h5>
                            
                            <hr class="my-2 border-secondary opacity-10" />

                            <!-- Tehničke specifikacije vozila -->
                            <p class="small font-monospace m-0 luxury-card-specs">
                                @post.Car.Year • @post.Car.FuelType • @post.Car.Kilometers.ToString("N0", CultureInfo.InvariantCulture) km
                            </p>
                            <p class="small font-monospace mb-2 luxury-card-specs">
                                @post.Car.TransmissionType
                            </p>
                        </div>

                        <!-- Lokacija na dnu kartice -->
                        <div class="mt-2">
                            <span class="small tracking-wider text-uppercase luxury-card-location">
                                <i class="fas fa-map-marker-alt me-1"></i>@post.Car.LocationCity
                            </span>
                        </div>
                    </div>

                </div>
            </div>
        }
    </div>

    <!-- Paginacija na dnu -->
    <div class="mt-5 p-3 border-top border-secondary border-opacity-10">
        <partial name="_PagingPartial" model="@Model" />
    </div>
</div>

@section Scripts
{
    <script>
        $(document).ready(function () {
            $("#sortingDropDown").change(function () {
                const sortingValue = $(this).val();
                const url = new URL(window.location.href);
                url.searchParams.set("sorting", sortingValue);
                window.location.href = url;
            });
        });
    </script>
}
