@page
@model Microsoft.AspNetCore.Identity.UI.Pages.Account.Manage.Internal.ChangePasswordModel
@{
    ViewData["Title"] = "Change Password";
}

<h4 class="text-uppercase font-monospace mb-4 luxury-profile-section-title">
    Update Password
</h4>

<partial name="_StatusMessage" model="@((string)ViewData["StatusMessage"] ?? (string)TempData["StatusMessage"])" />

<form id="change-password-form" method="post">
    <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

    <div class="form-floating mb-3 luxury-form-floating">
        <input asp-for="Input.OldPassword" class="form-control rounded-0 luxury-input-field" autocomplete="current-password" placeholder="Current password" />
        <label asp-for="Input.OldPassword" class="text-muted">Current Password</label>
        <span asp-validation-for="Input.OldPassword" class="text-danger small"></span>
    </div>

    <div class="form-floating mb-3 luxury-form-floating">
        <input asp-for="Input.NewPassword" class="form-control rounded-0 luxury-input-field" autocomplete="new-password" placeholder="New password" />
        <label asp-for="Input.NewPassword" class="text-muted">New Password</label>
        <span asp-validation-for="Input.NewPassword" class="text-danger small"></span>
    </div>

    <div class="form-floating mb-4 luxury-form-floating">
        <input asp-for="Input.ConfirmPassword" class="form-control rounded-0 luxury-input-field" autocomplete="new-password" placeholder="Confirm password" />
        <label asp-for="Input.ConfirmPassword" class="text-muted">Confirm New Password</label>
        <span asp-validation-for="Input.ConfirmPassword" class="text-danger small"></span>
    </div>

    <button id="change-password-button" type="submit" class="btn text-uppercase py-2.5 px-4 fw-bold border luxury-profile-save-btn">
        Change Password
    </button>
</form>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
