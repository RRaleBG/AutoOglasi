@using System.Globalization;
@model PostsListAdminAreaViewModel

@{
    ViewData["Title"] = "Control Dashboard";
}

<div class="py-3">
    <div class="text-center mb-4">
        <span class="text-uppercase small font-monospace luxury-gold-sub-text luxury-sub-spacing">Management Area</span>
        <h2 class="fw-light text-uppercase mt-1 text-theme-heading luxury-title-spacing">@ViewData["Title"]</h2>
        <div class="mx-auto mt-2 luxury-deco-line"></div>
    </div>

    <div class="table-responsive border border-secondary border-opacity-10 p-2 luxury-table-container">
        <table class="table table-hover align-middle m-0 luxury-admin-table">
            <thead class="text-uppercase font-monospace small luxury-table-header">
                <tr class="border-bottom border-secondary border-opacity-25">
                    <th scope="col" class="py-3 ps-3">Id</th>
                    <th scope="col" class="py-3">Make</th>
                    <th scope="col" class="py-3">Model</th>
                    <th scope="col" class="py-3">Year</th>
                    <th scope="col" class="py-3">Price</th>
                    <th scope="col" class="py-3 text-center">Status</th>
                    <th scope="col" class="py-3 text-end pe-3">Actions</th>
                </tr>
            </thead>
            
            <tbody>
                @foreach (var post in Model.Posts.Where(p => p != null))
                {
                    <tr class="border-bottom border-secondary border-opacity-10 luxury-table-row">
                        <td class="font-monospace small ps-3">@post.Car.Id</td>
                        <td class="fw-semibold text-theme-heading">@post.Car.Make</td>
                        <td>@post.Car.Model</td>
                        <td class="font-monospace">@post.Car.Year</td>
                        <td class="fw-bold luxury-table-price">
                            € @post.Car.Price.ToString("N0", CultureInfo.InvariantCulture)
                        </td>
                        <td class="text-center">
                            @if (post.IsPublic)
                            {
                                <span class="badge rounded-0 px-2 py-1 small text-uppercase font-monospace luxury-badge-active">Active</span>
                            }
                            else
                            {
                                <span class="badge rounded-0 px-2 py-1 small text-uppercase font-monospace luxury-badge-hidden">Hidden</span>
                            }
                        </td>
                        <td class="text-end pe-3">
                            <div class="d-inline-flex gap-1">
                                @if (post.IsPublic)
                                {
                                    <a asp-area="Admin" asp-controller="Posts" asp-action="ChangeVisibility" asp-route-id="@post.Id" 
                                       class="btn btn-sm rounded-0 text-uppercase font-monospace text-decoration-none px-2 py-1 luxury-admin-btn-hide">
                                        Hide
                                    </a>
                                }
                                else
                                {
                                    <a asp-area="Admin" asp-controller="Posts" asp-action="ChangeVisibility" asp-route-id="@post.Id" 
                                       class="btn btn-sm rounded-0 text-uppercase font-monospace text-decoration-none px-2 py-1 luxury-admin-btn-show">
                                        Show
                                    </a>
                                }

                                <a asp-area="" asp-controller="Posts" asp-action="Edit" asp-route-id="@post.Id" 
                                   class="btn btn-sm rounded-0 text-uppercase font-monospace text-decoration-none px-2 py-1 luxury-admin-btn-edit">
                                    Edit
                                </a>

                                <a asp-area="" asp-controller="Posts" asp-action="Offer" asp-route-id="@post.Id" 
                                   class="btn btn-sm rounded-0 text-uppercase font-monospace text-decoration-none px-2 py-1 luxury-admin-btn-view">
                                    View
                                </a>

                                <a asp-area="" asp-controller="Posts" asp-action="Delete" asp-route-id="@post.Id" 
                                   class="btn btn-sm rounded-0 text-uppercase font-monospace text-decoration-none px-2 py-1 luxury-admin-btn-delete">
                                    Delete
                                </a>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>

    <div class="mt-4 p-2 border-top border-secondary border-opacity-10">
        <partial name="_PagingPartial" model="@Model" />
    </div>
</div>
