@using System.Globalization
@model AutoOglasi.Web.ViewModels.Posts.LatestPostsViewModel

@{
    ViewData["Title"] = "Exclusive Fleet";
}

<div class="container-xl py-2">

    @if (!Model.LatestPosts.Any())
    {
        <div class="text-center py-5 my-5">
            <span class="text-uppercase small d-block mb-2 luxury-gold-sub-text luxury-sub-spacing">Showroom Empty</span>
            <h2 class="fw-light mb-4 text-theme-heading">Currently, there are no hypercars available.</h2>
            <a asp-controller="Posts" asp-action="Create" class="btn border text-uppercase px-4 py-2 luxury-btn-gold">
                Deliver a Vehicle
            </a>
        </div>
    }
    else
    {
        <div class="home-hero-container mb-5">
            <div id="homeHeroCarousel" class="carousel slide carousel-fade" data-bs-ride="carousel">
                <div class="carousel-inner">
                    @{
                        var postsList = Model.LatestPosts.ToList();
                        for (int i = 0; i < postsList.Count; i++)
                        {
                            <div class="carousel-item @(i == 0 ? "active" : "")">
                                <img src="@postsList[i].Car.CoverImage" class="d-block home-carousel-img" alt="Featured Hypercar" />
                                <div class="carousel-caption d-none d-md-block text-start start-50 translate-middle-x w-75 luxury-carousel-caption-bottom">
                                    <span class="text-uppercase small luxury-gold-sub-text luxury-sub-spacing">Just Arrived</span>
                                    <h1 class="display-4 fw-bold text-uppercase m-0 luxury-heading-spacing text-theme-heading">
                                        @postsList[i].Car.Make @postsList[i].Car.Model
                                    </h1>
                                    <a asp-controller="Posts" asp-action="Offer" asp-route-id="@postsList[i].Id" 
                                       class="text-decoration-none small luxury-gold-link-text luxury-link-spacing">
                                        VIEW ASSET <i class="fas fa-arrow-right ms-1 luxury-arrow-size"></i>
                                    </a>
                                </div>
                            </div>
                        }
                    }
                </div>
                <button class="carousel-control-prev" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="prev">
                    <span class="carousel-control-prev-icon" aria-hidden="true"></span>
                </button>
                <button class="carousel-control-next" type="button" data-bs-target="#homeHeroCarousel" data-bs-slide="next">
                    <span class="carousel-control-next-icon" aria-hidden="true"></span>
                </button>
            </div>
        </div>

        <div class="text-center mb-5">
            <span class="text-uppercase small luxury-gold-sub-text luxury-sub-spacing">Available Portfolio</span>
            <h2 class="fw-light text-uppercase mt-1 text-theme-heading luxury-heading-spacing">The Latest Acquisitions</h2>
            <div class="mx-auto mt-3 luxury-deco-line"></div>
        </div>

        <div class="row g-4 justify-content-center mb-5">
            @foreach (var post in Model.LatestPosts)
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 luxury-card overflow-hidden">
                        <a asp-controller="Posts" asp-action="Offer" asp-route-id="@post.Id" class="text-decoration-none d-flex flex-column h-100 luxury-card-link">
                            
                            <div class="d-flex justify-content-between align-items-center p-3 luxury-card-header">
                                <small class="luxury-card-date"><i class="far fa-calendar-alt me-1"></i>@post.PublishedOn</small>
                                <span class="fw-bold luxury-card-price">
                                    €@post.Car.Price.ToString("N0", CultureInfo.InvariantCulture)
                                </span>
                            </div>

                            <div class="overflow-hidden luxury-card-img-wrapper">
                                <img src="@post.Car.CoverImage"
                                     class="w-100 h-100 luxury-card-img"
                                     alt="@($"{post.Car.Make} {post.Car.Model}")" />
                            </div>

                            <div class="card-body text-center py-3 mt-auto luxury-card-body">
                                <h5 class="m-0 text-uppercase tracking-wide luxury-card-title">
                                    @post.Car.Make <span class="fw-bold luxury-card-model">@post.Car.Model</span>
                                </h5>
                            </div>
                        </a>
                    </div>
                </div>
            }
        </div>

        <div class="text-center my-5 pt-4">
            <button id="statistics-button" class="btn border text-uppercase px-4 py-3 luxury-stats-btn">
                <span><i class="bi bi-graph-up me-2"></i></span> Show Market Insights
            </button>

            <div id="statistics" class="d-none mt-4 row justify-content-center g-3">
                <div class="col-12 col-md-8 col-lg-6">
                    <div class="p-4 border border-secondary border-opacity-10 luxury-stats-box">
                        <div class="row text-center">
                            <div class="col-4">
                                <small class="d-block text-uppercase luxury-stats-label">Active Investors</small>
                                <span id="total-users" class="fs-4 fw-light luxury-stats-value">-</span>
                            </div>
                            <div class="col-4 border-start border-secondary border-opacity-25">
                                <small class="d-block text-uppercase luxury-stats-label">Vehicles Curated</small>
                                <span id="total-posts" class="fs-4 fw-light luxury-stats-value">-</span>
                            </div>
                            <div class="col-4 border-start border-secondary border-opacity-25">
                                <small class="d-block text-uppercase luxury-stats-label">Segments</small>
                                <span id="total-categories" class="fs-4 fw-light luxury-stats-value">-</span>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    }
</div>

@section Scripts
{
    <script>
        $(document).ready(function () {
            $('#statistics-button').click(function () {
                if ($('#statistics').hasClass('d-none')) {
                    $(this).html('<span><i class="bi bi-eye-slash me-2"></i></span> Hide Market Insights');

                    $.get('/api/statistics', (data) => {
                        $('#total-users').text(data.totalUsers);
                        $('#total-posts').text(data.totalPosts);
                        $('#total-categories').text(data.totalCategories);
                    });

                    $('#statistics').removeClass('d-none');
                } else {
                    $('#statistics').addClass('d-none');
                    $(this).html('<span><i class="bi bi-graph-up me-2"></i></span> Show Market Insights');                    
                }
            });
        });
    </script>
}
