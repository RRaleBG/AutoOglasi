@page
@model LoginModel

@{
    ViewData["Title"] = "Concierge Sign In";
}

<div class="d-flex justify-content-center align-items-center py-5">
    <div class="card luxury-card shadow-lg luxury-auth-card">
        <div class="card-body p-4 p-md-5">
            
            <div class="text-center mb-4">
                <span class="text-uppercase small font-monospace luxury-gold-sub-text luxury-sub-spacing-sm">Access Salon</span>
                <h2 class="fw-light text-uppercase mt-1 text-theme-heading luxury-title-spacing">Welcome Back</h2>
                <div class="mx-auto mt-2 luxury-deco-line-sm"></div>
            </div>

            <form id="account" method="post" asp-antifrogery="true">
                <div asp-validation-summary="ModelOnly" class="alert alert-danger border-0 rounded-0 small" role="alert"></div>

                <div class="form-floating mb-3 luxury-form-floating">
                    <input asp-for="Input.Email" class="form-control rounded-0 luxury-input-field" autocomplete="username" placeholder="name@example.com" />
                    <label asp-for="Input.Email" class="text-muted">Email address</label>
                    <span asp-validation-for="Input.Email" class="text-danger small"></span>
                </div>

                <div class="form-floating mb-3 luxury-form-floating">
                    <input asp-for="Input.Password" class="form-control rounded-0 luxury-input-field" autocomplete="current-password" placeholder="password" />
                    <label asp-for="Input.Password" class="text-muted">Password</label>
                    <span asp-validation-for="Input.Password" class="text-danger small"></span>
                </div>

                <div class="d-flex justify-content-between align-items-center mb-4">
                    <div class="form-check">
                        <input asp-for="Input.RememberMe" class="form-check-input rounded-0 luxury-admin-checkbox" />
                        <label asp-for="Input.RememberMe" class="form-check-label text-muted small">Remember me</label>
                    </div>
                    <a asp-page="./ForgotPassword" class="small text-decoration-none font-monospace luxury-forgot-password-link">Forgot password?</a>
                </div>

                <button id="login-submit" type="submit" class="btn text-uppercase py-3 w-100 fw-bold border mb-2 luxury-btn-gold-outline luxury-btn-size-md luxury-tracking-wide">
                    Log In
                </button>
            </form>

            @if ((Model.ExternalLogins?.Count ?? 0) > 0)
            {
                <hr class="my-4 border-secondary opacity-10" />
                <div class="text-center mb-3">
                    <p class="mb-3 text-muted small">Or sign in with</p>
                    <form id="external-account" asp-page="./ExternalLogin" asp-route-returnUrl="@Model.ReturnUrl" method="post" class="d-grid gap-2">
                        @foreach (var provider in Model.ExternalLogins)
                        {
                            <button type="submit" class="btn btn-outline-secondary py-2 text-uppercase small" name="provider" value="@provider.Name" title="Log in using your @provider.DisplayName account">
                                @provider.DisplayName
                            </button>
                        }
                    </form>
                </div>
            }

            <hr class="my-4 border-secondary opacity-10" />

            <div class="text-center">
                <p class="mb-3 text-muted small">Don't have an elite account?</p>
                <a asp-page="./Register" asp-route-returnUrl="@Model.ReturnUrl" class="btn btn-sm text-uppercase py-2 w-100 rounded-0 border mb-2 luxury-btn-cancel luxury-auth-btn-register">
                    Create Account
                </a>
                <a asp-page="./ResendEmailConfirmation" class="text-decoration-none small d-block mt-3 font-monospace luxury-resend-link">
                    Resend email confirmation
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
