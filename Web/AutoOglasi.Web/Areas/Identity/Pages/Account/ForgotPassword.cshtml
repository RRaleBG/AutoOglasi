@page
@model dynamic
@{
    ViewData["Title"] = "Forgot your password?";
}

<div class="container d-flex justify-content-center align-items-center min-vh-100">
    <div class="col-12 col-md-6 col-lg-5 p-4 border border-secondary border-opacity-10 shadow-lg autooglasi-recovery-box">
        
        <h2 class="text-uppercase font-monospace text-center mb-2 autooglasi-recovery-title text-theme-heading">
            Recovery Vault
        </h2>
        <p class="text-center small font-monospace mb-4 autooglasi-recovery-subtitle">
            Enter your email to reset credentials
        </p>

        <partial name="_StatusMessage" model="@((string)ViewData["StatusMessage"] ?? (string)TempData["StatusMessage"])" />

        <form method="post">
            <div asp-validation-summary="All" class="text-danger small mb-3"></div>

            <div class="form-floating mb-4 luxury-form-floating">
                <input type="email" name="Input.Email" id="emailInput" class="form-control rounded-0 font-monospace luxury-input-field" autocomplete="email" aria-required="true" placeholder="name@example.com" />
                <label for="emailInput" class="text-muted">Registered Email Address</label>
            </div>

            <button type="submit" class="btn text-uppercase py-2.5 w-100 fw-bold border autooglasi-recovery-btn">
                Send Reset Link
            </button>
        </form>

    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
