@model AutoOglasi.Web.ViewModels.Posts.SearchPostInputModel

@{
    ViewData["Title"] = "Inventory Configuration";
}

<div class="py-3 justify-content-center row">
    <div class="col-12 col-lg-10 col-xl-9">
        
        <div class="text-center mb-5">
            <span class="text-uppercase small font-monospace luxury-gold-sub-text luxury-sub-spacing">Search Engine</span>
            <h2 class="fw-light text-uppercase mt-1 text-theme-heading luxury-title-spacing">Configure Your Search</h2>
            <div class="mx-auto mt-2 luxury-deco-line"></div>
        </div>

        <form method="get" asp-action="All" class="p-4 p-md-5 border border-secondary border-opacity-10 luxury-search-form">
            
            <div class="row mb-4">
                <div class="col-12">
                    <label asp-for="@Model.Car.TextSearchTerm" class="form-label text-uppercase small font-monospace tracking-wider luxury-search-label">Keyword or Specification</label>
                    <input asp-for="@Model.Car.TextSearchTerm" class="form-control" placeholder="e.g., Chiron, Carbon Package, V12...">
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-3 g-4 mb-4">        
                
                <div class="col">
                    <label class="form-label text-uppercase small font-monospace luxury-search-label">Production Year</label>       
                    <input asp-for="@Model.Car.FromYear" class="form-control mb-2 small" placeholder="From (Year)">
                    <span asp-validation-for="@Model.Car.FromYear" class="text-danger small"></span>
                    
                    <input asp-for="@Model.Car.ToYear" class="form-control small" placeholder="To (Year)">
                    <span asp-validation-for="@Model.Car.ToYear" class="text-danger small"></span>
                </div>

                <div class="col">
                   <label class="form-label text-uppercase small font-monospace luxury-search-label">Performance (BHP)</label>
                   <input asp-for="@Model.Car.MinHorsepower" class="form-control mb-2 small" placeholder="Min BHP">
                   <span asp-validation-for="@Model.Car.MinHorsepower" class="text-danger small"></span>

                   <input asp-for="@Model.Car.MaxHorsepower" class="form-control small" placeholder="Max BHP">
                   <span asp-validation-for="@Model.Car.MaxHorsepower" class="text-danger small"></span>
                </div>

                <div class="col">           
                    <label class="form-label text-uppercase small font-monospace luxury-search-label">Investment Range (€)</label>
                    <input asp-for="@Model.Car.MinPrice" min="0" class="form-control mb-2 small" placeholder="Min Vrednost">
                    <span asp-validation-for="@Model.Car.MinPrice" class="text-danger small"></span>
                        
                    <input asp-for="@Model.Car.MaxPrice" class="form-control small" placeholder="Max Vrednost">
                    <span asp-validation-for="@Model.Car.MaxPrice" class="text-danger small"></span>            
                </div>
            </div>

            <div class="row row-cols-1 row-cols-md-3 g-4 pt-3 border-top border-secondary border-opacity-10 mb-4">
                
                <div class="col">
                    <h6 class="text-uppercase font-monospace pb-2 border-bottom border-secondary border-opacity-10 luxury-search-section-title">Category</h6>
                    <div class="pt-2 style-scroll luxury-scroll-container">
                        @foreach (var category in Model.Car.Categories)
                        {
                            <div class="form-check my-2">
                                <input id="category_@category.Id" class="form-check-input luxury-checkbox" type="checkbox" name="SelectedCategoriesIds" value="@category.Id" @(Model.SelectedCategoriesIds.Contains(category.Id) ? "checked" : "")>
                                <label class="form-check-label luxury-checkbox-label" for="category_@category.Id">@category.Name</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="col">
                    <h6 class="text-uppercase font-monospace pb-2 border-bottom border-secondary border-opacity-10 luxury-search-section-title">Propulsion</h6>
                    <div class="pt-2">
                        @foreach (var fuelType in Model.Car.FuelTypes)
                        {
                            <div class="form-check my-2">
                                <input id="fuelType_@fuelType.Id" class="form-check-input luxury-checkbox" type="checkbox" name="SelectedFuelTypesIds" value="@fuelType.Id" @(Model.SelectedFuelTypesIds.Contains(fuelType.Id) ? "checked" : "")>
                                <label class="form-check-label luxury-checkbox-label" for="fuelType_@fuelType.Id">@fuelType.Name</label>
                            </div>
                        }
                    </div>
                </div>

                <div class="col">
                    <h6 class="text-uppercase font-monospace pb-2 border-bottom border-secondary border-opacity-10 luxury-search-section-title">Transmission</h6>
                    <div class="pt-2">
                        @foreach (var transmissionType in Model.Car.TransmissionTypes)
                        {
                            <div class="form-check my-2">
                                <input id="transmissionType_@transmissionType.Id" class="form-check-input luxury-checkbox" type="checkbox" name="SelectedTransmissionTypesIds" value="@transmissionType.Id" @(Model.SelectedTransmissionTypesIds.Contains(transmissionType.Id) ? "checked" : "")>
                                <label class="form-check-label luxury-checkbox-label" for="transmissionType_@transmissionType.Id">@transmissionType.Name</label>
                            </div>
                        }
                    </div>
                </div>
            </div>

            <div class="text-center pt-3">
                <button type="submit" class="btn text-uppercase py-3 px-5 fw-bold border w-100 w-md-auto luxury-search-btn">
                    <i class="fas fa-search me-2"></i> Execute Search
                </button>
            </div>

        </form>
    </div>
</div>
