
<h3> 
    @{
        ViewData["Title"] = "All";
    } 
</h3>


@* <h2 class="heading-margin text-center">@(Model.PagesCount > 1 ? $" {Model.PageNumber}" : string.Empty)</h2> *@

<partial name="_SortingPartial" model="@Model" />

<hr class="border-info" />


<div class="row justify-content-center g-3">

    @foreach (var post in Model.Posts)
    {
        <div class="col-md-4 col-lg-3">
            <div class="card h-100 shadow-info border-0 rounded-3 overflow-hidden">

                <!-- Header sa datumom i cenom -->
                <div class="d-flex justify-content-between align-items-center p-2">
                    <small class="text-muted">@post.PublishedOn</small>
                    <span class="badge text-bg-warning fw-bold "> € @post.Car.Price.ToString("N", CultureInfo.InvariantCulture).Replace(".00", string.Empty)</span>
                </div>

                <!-- Slika -->
                <a asp-action="Offer" asp-route-id="@post.Id" class="text-decoration-none">
                    <img src="@post.Car.CoverImage"
                         class="card-img-top img-fluid"
                         style="height: 200px; object-fit: cover;"
                         alt="@($"{post.Car.Make} {post.Car.Model}")" />
                </a>

                <!-- Body -->
                <div class="card-body text-center">
                    <h5 class="card-title fw-bold text-primary">
                        @post.Car.Make @post.Car.Model
                    </h5>

                    <hr class="mt-2 mb-3 border-info" />

                    <p class="card-text text-muted small">
                        @post.Car.Year • @post.Car.FuelType • @post.Car.Kilometers km • @post.Car.TransmissionType
                    </p>

                    <p class="card-text text-info fw-semibold">
                        @post.Car.LocationCity, @post.Car.LocationCountry
                    </p>
                </div>
            </div>
        </div>
    }
</div>

<hr class="border-info" />

<partial name="_PagingPartial" model="@Model" />

@section Scripts
{
    <script>
        $(document).ready(function(){
            $(".owl-carousel").owlCarousel();
        });
    </script>


    <script>

        $(document).ready(function () {
            $("#sortingDropDown").change(function () {
                const sortingValue = $(this).val();
                const url = new URL(window.location.href);

                url.searchParams.set("sorting", sortingValue);
                window.location.href = url;
            });
        });

    </script>
}

