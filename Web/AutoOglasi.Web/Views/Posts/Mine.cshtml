@model AutoOglasi.Web.ViewModels.Posts.PostsByUserViewModel

@{
    ViewData["Title"] = "My Listings";
}

<div class="py-2">
    <div class="p-3 mb-4 luxury-sorting-bar border border-secondary border-opacity-10">
        <h4 class="m-0">My Cars</h4>
    </div>

    <div class="row justify-content-center g-4">
        @if (Model.Posts == null) {
            <div class="col-12 text-center small text-muted">You have no listings yet.</div>
        } else {
            foreach (var post in Model.Posts)
            {
                <div class="col-12 col-md-6 col-lg-4 col-xl-3">
                    <div class="card h-100 luxury-card">
                        <div class="d-flex justify-content-between align-items-center p-3 luxury-card-header">
                            <small class="luxury-card-date"><i class="far fa-calendar-alt me-1"></i>@post.PublishedOn</small>
                            <span class="fw-bold luxury-card-price">€ @post.Car.Price.ToString("N0", System.Globalization.CultureInfo.InvariantCulture)</span>
                        </div>

                        <a asp-action="Offer" asp-route-id="@post.Id" class="text-decoration-none">
                            <div class="luxury-card-img-wrapper">
                                <img src="@post.Car.CoverImage" class="luxury-card-img" alt="@post.Car.Make @post.Car.Model" />
                            </div>
                        </a>

                        <div class="card-body d-flex flex-column justify-content-between text-center p-3 luxury-card-body">
                            <div>
                                <h5 class="text-uppercase tracking-wide mb-2 luxury-card-title">
                                    @post.Car.Make <span class="fw-light luxury-card-model">@post.Car.Model</span>
                                </h5>
                                <hr class="my-2 border-secondary opacity-10" />
                                <p class="small font-monospace m-0 luxury-card-specs">Year: @post.Car.Year</p>
                            </div>

                            <div class="mt-3 d-flex justify-content-between w-100">
                                <a asp-action="Edit" asp-route-id="@post.Id" class="btn btn-outline-secondary btn-sm">Edit</a>
                                <form asp-action="Delete" asp-route-id="@post.Id" method="post" onsubmit="return confirm('Delete this listing?');">
                                    <button type="submit" class="btn btn-outline-danger btn-sm">Delete</button>
                                </form>
                                <a asp-action="Offer" asp-route-id="@post.Id" class="btn btn-outline-primary btn-sm">View</a>
                            </div>
                        </div>
                    </div>
                </div>
            }
        }
    </div>

    <div class="mt-5 p-3 border-top border-secondary border-opacity-10">
        <partial name="_PagingPartial" model="@Model" />
    </div>
</div>

@section Scripts
{
    <script>
        $(document).ready(function () {
            // client-side behavior for Mine page if needed
        });
    </script>
}
