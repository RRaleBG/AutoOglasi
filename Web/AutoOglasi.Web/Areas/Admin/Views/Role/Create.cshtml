@model string
@{
    ViewData["Title"] = "Create Privilege";
}

<div class="py-5 justify-content-center row">
    <div class="col-12 col-md-6 col-lg-5">

        <div class="text-center mb-4">
            <span class="text-uppercase small font-monospace" style="letter-spacing: 4px; color: #d4af37;">Security Hub</span>
            <h2 class="text-white fw-light text-uppercase mt-1" style="letter-spacing: 1px;">Create New Role</h2>
            <div class="mx-auto mt-2" style="width: 30px; height: 1px; background-color: #d4af37;"></div>
        </div>

        <div class="card luxury-card shadow-lg">
            <div class="card-body p-4 p-md-5">

                <div asp-validation-summary="All" class="alert alert-danger border-0 rounded-0 small mb-4" role="alert"></div>

                <form asp-action="Create" method="post">

                    <div class="form-floating mb-4">
                        <input name="name" id="roleNameInput" class="form-control text-white bg-dark bg-opacity-20 border-secondary border-opacity-25 rounded-0" placeholder="Role name" required />
                        <label for="roleNameInput" class="text-muted">Role Name</label>
                    </div>

                    <div class="d-grid gap-2 d-md-flex justify-content-md-between pt-2">
                        <button type="submit" class="btn text-uppercase py-2.5 px-4 fw-bold border order-md-2" 
                                style="color: #d4af37; border-color: #d4af37 !important; letter-spacing: 1px; font-size: 0.8rem; background: transparent; transition: all 0.3s;">
                            <i class="fas fa-check-circle me-1"></i> Create Role
                        </button>
                        
                        <a asp-action="Index" class="btn text-uppercase py-2.5 px-4 rounded-0 border order-md-1"
                           style="color: #c5c6c7; border-color: rgba(255,255,255,0.15); background: rgba(255,255,255,0.02); font-size: 0.8rem; letter-spacing: 1px;">
                            Cancel
                        </a>
                    </div>
                </form>

            </div>
        </div>

    </div>
</div>
